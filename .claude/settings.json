{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Read",
      "Grep",
      "Glob",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(ls:*)",
      "Bash(find:*)",
      "Bash(wc:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(file:*)",
      "Bash(unzip -l:*)",
      "Bash(unzip -Z1:*)",
      "Bash(npm run build:*)",
      "Bash(npm run preview:*)",
      "Bash(cp:*)",
      "Bash(mkdir:*)",
      "Bash(zip:*)",
      "Bash(rm:*)"
    ],
    "deny": [
      "Bash(npm install:*)",
      "Bash(npm ci:*)",
      "Bash(npm i:*)",
      "Bash(npm add:*)",
      "Bash(npm update:*)",
      "Bash(yarn add:*)",
      "Bash(yarn install:*)",
      "Bash(yarn:*)",
      "Bash(pnpm add:*)",
      "Bash(pnpm install:*)",
      "Bash(pnpm i:*)",
      "Bash(pip install:*)",
      "Bash(pip3 install:*)",
      "Bash(pipenv install:*)",
      "Bash(poetry add:*)",
      "Bash(poetry install:*)",
      "Bash(conda install:*)",
      "Bash(brew install:*)",
      "Bash(npx:*)",
      "Edit(Plugin/owismind/resource/owismind-app/**)",
      "Write(Plugin/owismind/resource/owismind-app/**)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/guardrail.sh"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$CLAUDE_PROJECT_DIR\"/.claude/hooks/session-start.sh"
          }
        ]
      }
    ]
  }
}
